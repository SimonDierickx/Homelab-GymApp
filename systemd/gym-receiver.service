[Unit]
Description=Gym Data Receiver
After=network.target

[Service]
User=coach
WorkingDirectory=/home/coach/projects/gym_receiver
EnvironmentFile=/opt/claude-coach/.env
ExecStart=/home/coach/projects/gym_receiver/venv/bin/uvicorn gym_receiver:app --host 0.0.0.0 --port 8081
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

